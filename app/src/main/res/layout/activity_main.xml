<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050B12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ÜST BAR -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#00ACC1"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#FFFFFF"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Media IPTV Player"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_search"
                android:tint="#FFFFFF"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="30dp"
            android:text="Hoş Geldiniz"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Media IPTV Player"
            android:textColor="#00BCD4"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="30dp"
            android:text="Canlı TV, filmler ve dizileri kolayca izleyin."
            android:textColor="#BBBBBB"
            android:textSize="18sp"/>

        <Button
            android:id="@+id/cardLive"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_margin="16dp"
            android:backgroundTint="#00BCD4"
            android:text="CANLI TV"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="26sp"/>

        <Button
            android:id="@+id/cardMovies"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="#00BCD4"
            android:text="FİLMLER"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="26sp"/>

        <Button
            android:id="@+id/cardSeries"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_margin="16dp"
            android:backgroundTint="#00BCD4"
            android:text="DİZİLER"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="26sp"/>

        <Button
            android:id="@+id/cardPlaylists"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:backgroundTint="#00BCD4"
            android:text="KAYITLI LİSTELER"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="26sp"/>

        <Button
            android:id="@+id/cardSettings"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_margin="16dp"
            android:layout_marginBottom="30dp"
            android:backgroundTint="#00BCD4"
            android:text="AYARLAR"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="26sp"/>

    </LinearLayout>

</ScrollView>
