<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06131A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ÜST BAR -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="#18C7D1"
            android:gravity="center_vertical"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Media IPTV Player"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- HOŞ GELDİNİZ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="24dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="#18C7D1"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoş Geldiniz"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Media IPTV Player"
                    android:textColor="#18C7D1"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Canlı TV, filmler ve dizileri kolayca izleyin."
                    android:textColor="#BDBDBD"
                    android:textSize="18sp"/>
            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnLiveTv"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:backgroundTint="#101C24"
            android:text="📺  CANLI TV"
            android:textColor="#FFFFFF"
            android:textSize="24sp"/>

        <Button
            android:id="@+id/btnMovies"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:backgroundTint="#101C24"
            android:text="🎬  FİLMLER"
            android:textColor="#FFFFFF"
            android:textSize="24sp"/>

        <Button
            android:id="@+id/btnSeries"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:backgroundTint="#101C24"
            android:text="🎞️  DİZİLER"
            android:textColor="#FFFFFF"
            android:textSize="24sp"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_margin="12dp"
            android:backgroundTint="#101C24"
            android:text="⚙️  AYARLAR"
            android:textColor="#FFFFFF"
            android:textSize="24sp"/>

    </LinearLayout>

</ScrollView>
