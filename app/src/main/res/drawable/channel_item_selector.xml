<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Basılı -->

    <item android:state_pressed="true">

        <shape>

            <gradient
                android:startColor="#FF9800"
                android:endColor="#FFC107"
                android:angle="0"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="14dp"/>

        </shape>

    </item>

    <!-- Kumanda / Air Mouse -->

    <item android:state_focused="true">

        <shape>

            <gradient
                android:startColor="#1565C0"
                android:endColor="#42A5F5"
                android:angle="0"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="14dp"/>

        </shape>

    </item>

    <!-- Seçili -->

    <item android:state_selected="true">

        <shape>

            <gradient
                android:startColor="#00897B"
                android:endColor="#26A69A"
                android:angle="0"/>

            <stroke
                android:width="4dp"
                android:color="#FFFFFF"/>

            <corners android:radius="14dp"/>

        </shape>

    </item>

    <!-- Normal -->

    <item>

        <shape>

            <solid android:color="#10212A"/>

            <stroke
                android:width="2dp"
                android:color="#203040"/>

            <corners android:radius="14dp"/>

        </shape>

    </item>

</selector>
